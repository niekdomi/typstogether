# Copy to `.env` and fill in real values for local development.
# Tests load `.env.test` automatically via NODE_ENV=test; do not put test values here.

# Postgres connection string (required).
DATABASE_URL=postgres://typstogether:typstogether@localhost:5432/typstogether

# Hocuspocus collaboration server port (defaults to 3001).
COLLAB_PORT=3001

# Better Auth.
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string

# OAuth providers — leave blank to disable a provider locally.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_ISSUER=https://gitlab.ost.ch
