{
  "name": "typstogether",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check": "bun run --filter '*' check",
    "test": "bun run --filter '*' test",
    "lint": "prettier --check . '!backend/drizzle/**' && eslint .",
    "format": "prettier --write . '!backend/drizzle/**'",
    "clean": "rm -rf node_modules frontend/node_modules backend/node_modules frontend/dist backend/dist"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "prettier": {
    "trailingComma": "es5",
    "printWidth": 100,
    "proseWrap": "always",
    "plugins": [
      "prettier-plugin-svelte"
    ]
  }
}
