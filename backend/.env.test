# Loaded automatically by Bun when NODE_ENV=test (i.e. `bun test`).
# Tests mock the DB via test/setup.ts, so DATABASE_URL just needs to be set.
# OAuth values silence Better Auth's "missing clientId/clientSecret" warnings.
DATABASE_URL=postgres://test:test@localhost:5432/test
GITHUB_CLIENT_ID=test
GITHUB_CLIENT_SECRET=test
GOOGLE_CLIENT_ID=test
GOOGLE_CLIENT_SECRET=test
GITLAB_CLIENT_ID=test
GITLAB_CLIENT_SECRET=test
