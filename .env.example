# Copy to `.env` and fill in real values for `docker compose up`. For local
# `bun run dev`, configure `.env.dev` instead (OAuth callbacks differ between
# dev and prod, so each environment uses its own provider credentials).

# Public URL of the deployment. Caddy serves both frontend and backend at this
# origin and provisions TLS automatically when the scheme is https. Leave unset
# to fall back to http://localhost for local docker compose.
# Used by the backend (OAuth callback guard, CORS, BETTER_AUTH_URL) and baked
# into the frontend at build time as VITE_API_URL.
FRONTEND_URL=

# Postgres password for the bundled `db` service. The backend's DATABASE_URL is
# constructed from this in docker-compose.yaml.
POSTGRES_PASSWORD=

# Better Auth secret — generate with `openssl rand -base64 32`.
# BETTER_AUTH_URL is derived from FRONTEND_URL in docker-compose.yaml since
# Caddy fronts both at the same origin.
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string

# OAuth providers (production credentials). Leave a pair blank to disable that
# provider. Dev credentials live in `.env.dev`.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_ISSUER=https://gitlab.ost.ch
