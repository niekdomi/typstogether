# Copy to `.env` and fill in real values for `docker compose up`.
# For local `bun run dev`, configure `backend/.env` instead.

# Caddy serves both frontend and backend at this host. Set to your domain in
# production; Caddy will provision a TLS cert automatically. For local docker
# compose, leave blank to fall back to `localhost` (HTTP only).
DOMAIN=

# Public URL of the deployment. Same origin as DOMAIN since Caddy fronts both.
# Used by the backend (OAuth callback guard) and baked into the frontend at
# build time as VITE_API_URL.
FRONTEND_URL=https://example.com

# Postgres password for the bundled `db` service. The backend's DATABASE_URL is
# constructed from this in docker-compose.yaml.
POSTGRES_PASSWORD=

# Better Auth. BETTER_AUTH_URL must match the public origin.
BETTER_AUTH_URL=https://example.com
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string

# OAuth providers — leave blank to disable a provider.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_ISSUER=https://gitlab.ost.ch
