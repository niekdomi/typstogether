{
  "name": "@typstogether/backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "check": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.9",
    "@elysiajs/cors": "^1.4.2",
    "@hocuspocus/extension-database": "^4.0.0",
    "@hocuspocus/extension-logger": "^4.0.0",
    "@hocuspocus/server": "^4.0.0",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "drizzle-kit": "^0.31.10"
  }
}
