# Copy to `.env.dev` and fill in real values to enable OAuth login during
# `bun run dev`. These should be the *dev* OAuth app credentials — callback
# URIs point to http://localhost:3000. Production credentials live in `.env`.
# Leave a pair blank to disable that provider.

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_ISSUER=https://gitlab.ost.ch
